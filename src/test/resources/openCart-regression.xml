<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OpenCart Regression Suite"
       verbose="1"
       parallel="methods"
       thread-count="2"
       configfailurepolicy="continue">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="headless" value="false"/>
    <parameter name="baseUrl" value="https://www.opencart.com/index.php?route=cms/demo"/>
    <parameter name="storeUrl" value="https://opencart.chankov.net/4/"/>

    <test name="OpenCart Regression Tests" preserve-order="false">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="org.opencart.tests"/>
        </packages>
    </test>
</suite>
